      "cacheVariables": {
        "CKRE_BUILD_SHARED": "ON",
        "CKRE_BUILD_STATIC": "OFF",
        "CKRE_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "renderengine-dx9-static-msvc-win32",
      "displayName": "RenderEngine DX9 Static (MSVC Win32)",
      "description": "Build static RenderEngine and DX9 rasterizer libraries.",
