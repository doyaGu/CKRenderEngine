{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "msvc-win32-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "architecture": "Win32",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "msvc-x64-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "renderengine-dx9-runtime-msvc-win32",
      "displayName": "RenderEngine DX9 Runtime (MSVC Win32)",
      "description": "Build the current DX9 rasterizer runtime using shared libraries.",
      "inherits": "msvc-win32-base",
      "cacheVariables": {
        "CKRE_BUILD_SHARED": "ON",
        "CKRE_BUILD_STATIC": "OFF",
        "CKRE_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "renderengine-dx9-runtime-msvc-x64",
      "displayName": "RenderEngine DX9 Runtime (MSVC x64)",
      "description": "Build the x64 DX9 rasterizer runtime using shared libraries.",
