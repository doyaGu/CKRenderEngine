      "cacheVariables": {
        "CKRE_BUILD_SHARED": "OFF",
        "CKRE_BUILD_STATIC": "ON",
        "CKRE_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "renderengine-dx9-tests-msvc-win32",
      "displayName": "RenderEngine DX9 Tests (MSVC Win32)",
      "description": "Build RenderEngine tests against static CKRenderEngine libraries.",
      "inherits": "renderengine-dx9-static-msvc-win32",
      "cacheVariables": {
        "CKRE_BUILD_SHARED": "OFF",
        "CKRE_BUILD_STATIC": "ON",
        "CKRE_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "renderengine-dx9-tests-msvc-x64",
      "displayName": "RenderEngine DX9 Tests (MSVC x64)",
      "description": "Build x64 RenderEngine tests against static CKRenderEngine libraries.",
      "inherits": "renderengine-dx9-static-msvc-x64",
      "cacheVariables": {
        "CKRE_BUILD_SHARED": "OFF",
        "CKRE_BUILD_STATIC": "ON",
        "CKRE_BUILD_TESTS": "ON"
      }
    }
